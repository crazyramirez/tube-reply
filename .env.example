# ──────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────

# Generate hash: npm run hash-password
# SECURITY NOTE: This is a BCrypt hash of your master password. BCrypt is a slow, 
# salted hashing algorithm designed to be resistant to brute-force attacks. 
# By storing only the hash, your real password is never present in the database 
# or server memory, providing protection even if the environment is compromised.
ADMIN_PASSWORD_HASH=<bcrypt_hash_of_your_password>

SESSION_DURATION_HOURS=24

# ──────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────
DATABASE_URL=./data/youtube.db

# ──────────────────────────────────────────────────
# YouTube OAuth2
# Create at: https://console.cloud.google.com/apis/credentials
# Scopes: youtube.readonly + youtube.force-ssl
# ──────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://yourdomain.com/api/youtube/callback

# ──────────────────────────────────────────────────
# Google Gemini
# Get at: https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# ──────────────────────────────────────────────────
# OpenAI
# Get at: https://platform.openai.com/api-keys
# ──────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# ──────────────────────────────────────────────────
# Token encryption (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be exactly 64 hex chars (32 bytes)
#
# SECURITY NOTE: This key is used for AES-256-GCM encryption of sensitive 
# YouTube OAuth tokens. AES-256 is the industry standard for high-security 
# data encryption. GCM mode provides authenticated encryption, ensuring both 
# data confidentiality and integrity. This ensures that even if your database 
# file is accessed, your YouTube account remains protected as tokens are 
# encrypted at rest.
# ──────────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=<64_random_hex_chars>

# ──────────────────────────────────────────────────
# Sync scheduler
# ──────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=30
MAX_QUOTA_PER_DAY=8500
# Set to false in dev to avoid consuming YouTube quota on every restart of your Server
AUTO_SYNC_ON_START=true

# ──────────────────────────────────────────────────
# Rate limiting & lockout
#
# SECURITY NOTE: Protects the login endpoint from automated brute-force 
# attacks and credential stuffing. These settings determine the maximum 
# attempts per window before a temporary IP-based lockout is enforced.
# ──────────────────────────────────────────────────
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15
LOCKOUT_DURATION_MINUTES=30

# ──────────────────────────────────────────────────
# Cleanup DDBB Logs/Errors
# ──────────────────────────────────────────────────
LOG_RETENTION_DAYS=30